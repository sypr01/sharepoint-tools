{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/ddfac243-a888-4ed6-8fb0-bc8557897b74/v2.0",
          "clientIdSettingName": "CLIENT_ID",
          "clientSecretSettingName": "CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/portal-plg.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "rewrite": "/login.html"
    },
    {
      "route": "/directorio-colaboradores",
      "rewrite": "/directorio-colaboradores.html"
    },
    {
      "route": "/directorio",
      "rewrite": "/directorio.html"
    },
    {
      "route": "/tickets",
      "rewrite": "/tickets.html"
    },
    {
      "route": "/soporte",
      "rewrite": "/soporte.html"
    },
    {
      "route": "/inventario",
      "rewrite": "/inventario.html"
    },
    {
      "route": "/admin-usuarios",
      "rewrite": "/admin-usuarios.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.html", "/*.js", "/*.css", "/*.png", "/*.jpg", "/*.svg", "/*.ico", "/*.json"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/portal-plg.html",
      "statusCode": 302
    }
  }
}
